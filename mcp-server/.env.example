# --- Credenciales de Firebase (servicio) ---
# Opcion A: ruta al archivo JSON de la llave de servicio descargada de Firebase.
FIREBASE_SERVICE_ACCOUNT=./serviceAccount.json
# Opcion B (para la nube): el JSON completo codificado en base64.
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# UID del usuario dueno de la agenda (con el que actuara el asistente).
# Lo encuentras en Firebase Authentication, columna "Identificador de usuario".
AGENDA_UID=

# (Opcional) Agenda por defecto. Si se deja vacio, usa la agenda personal del UID.
# AGENDA_DEFAULT_WORKSPACE=

# (Opcional) Zona horaria para interpretar fechas y horas. Colombia = -05:00
AGENDA_TZ_OFFSET=-05:00

# --- Solo para el modo nube (HTTP, para ChatGPT) ---
MCP_HTTP_PORT=8787
# Token secreto que ChatGPT debe enviar para autenticarse. Invéntate uno largo.
MCP_BEARER_TOKEN=
