rules_version = '2';

// Reglas de Firebase Storage para Agenda Mentes Brillantes.
// Los archivos (imagenes y documentos) de un evento se guardan en
// attachments/{workspaceId}/{eventId}/...  y solo los miembros de esa
// agenda pueden leerlos o subirlos.

service firebase.storage {
  match /b/{bucket}/o {

    // Comprueba en Firestore si el usuario es miembro de la agenda.
    function isMember(wsId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
    }

    match /attachments/{wsId}/{eventId}/{fileName} {
      allow read: if isMember(wsId);
      allow create, update: if isMember(wsId)
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf|application/msword|application/vnd\\.openxmlformats-officedocument\\..*|application/vnd\\.ms-.*|text/.*|application/rtf|application/zip|application/x-zip-compressed');
      allow delete: if isMember(wsId);
    }

    // Imagenes antiguas (modelo anterior de una sola imagen por evento).
    match /event-images/{userId}/{eventId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
